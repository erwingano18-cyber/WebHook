{
  "name": "webflow-webhook-suitecrm-dashboard",
  "version": "1.0.0",
  "description": "Fullstack Webflow webhook app with Express, MySQL, React Vite, and Redux",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "nodemon src/server.js",
    "dev:client": "npm --prefix client run dev",
    "build:client": "npm --prefix client run build",
    "preview:client": "npm --prefix client run preview"
  },
  "keywords": [
    "webflow",
    "webhook",
    "suitecrm",
    "dashboard",
    "leads"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.11.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "google-auth-library": "^10.9.1",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.14.3",
    "nodemailer": "^6.10.1"
  },
  "devDependencies": {
    "concurrently": "^9.2.0",
    "nodemon": "^3.1.10"
  }
}
